{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "moduleResolution": "bundler",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": [
      "node",
      "vite/client"
    ],
    "paths": {
      "phial": [
        "../../../dist/index.d.ts"
      ],
      "phial/vite": [
        "../../../dist/vite.d.ts"
      ],
      "@hornjs/fest": [
        "../../../../../node_modules/@hornjs/fest/dist/index.d.mts"
      ],
      "@hornjs/fest/utils": [
        "../../../../../node_modules/@hornjs/fest/dist/utils.d.mts"
      ]
    }
  },
  "include": [
    "../app/**/*.ts",
    "../app/**/*.tsx",
    "../app/**/*.vue",
    "../server/**/*.ts",
    "./types/**/*.d.ts",
    "../phial.config.ts"
  ],
  "exclude": [
    "../node_modules",
    "../.output",
    "../dist"
  ]
}