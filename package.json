{
  "name": "phial",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "author": "Maofeng <hornjs@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/hornjs/phial#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hornjs/phial.git"
  },
  "bugs": {
    "url": "https://github.com/hornjs/phial/issues"
  },
  "bin": {
    "phial": "./bin/phial.mjs"
  },
  "files": [
    "dist",
    "bin/phial.mjs",
    "LICENSE",
    "README.md"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./vite-plugin": "./src/vite-plugin.ts",
    "./cli": "./src/cli.ts",
    "./generated-routes-manifest": "./src/lib/generated-routes.d.ts",
    "./generated-routes-modules": "./src/lib/generated-routes.d.ts",
    "./generated-app-runtime": "./src/lib/generated-routes.d.ts",
    "./generated-app-loader": "./src/lib/generated-routes.d.ts",
    "./generated-app-middleware": "./src/lib/generated-routes.d.ts",
    "./generated-app-plugin": "./src/lib/generated-routes.d.ts",
    "./generated-server-routes": "./src/lib/generated-routes.d.ts",
    "./generated-server-middleware": "./src/lib/generated-routes.d.ts",
    "./generated-server-plugin": "./src/lib/generated-routes.d.ts",
    "./generated-config": "./src/lib/generated-routes.d.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "directories": {
      "src": "dist"
    }
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "example:zero-config": "pnpm build && node bin/phial.mjs dev examples/zero-config",
    "test": "vitest",
    "smoke:hmr": "node scripts/hmr-smoke.mjs",
    "smoke:server-routes": "node scripts/server-routes-smoke.mjs",
    "typecheck": "vue-tsc --noEmit -p tsconfig.app.json && tsc --noEmit -p tsconfig.node.json",
    "release": "bumpp",
    "prepare:publish": "prepare-publish --print-tree",
    "prepare:publish:dry-run": "prepare-publish --dry-run",
    "prepublishOnly": "pnpm run build && pnpm run prepare:publish"
  },
  "dependencies": {
    "@hornjs/fest": "latest",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "fs-route-ir": "latest",
    "vuepagelet": "latest"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "playwright": "^1.58.2",
    "prepare-publish": "^0.1.0",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "8.0.2",
    "vitest": "^4.1.2",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4",
    "vue-tsc": "^3.2.5"
  },
  "peerDependencies": {
    "vite": "^8.0.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  }
}
