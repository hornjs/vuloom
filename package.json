{
  "name": "phial",
  "version": "0.0.0",
  "type": "module",
  "description": "",
  "author": "Maofeng <hornjs@qq.com>",
  "license": "MIT",
  "homepage": "https://github.com/hornjs/phial#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hornjs/phial.git"
  },
  "bugs": {
    "url": "https://github.com/hornjs/phial/issues"
  },
  "bin": {
    "phial": "./bin/phial.mjs"
  },
  "files": [
    "dist",
    "bin/phial.mjs",
    "src/lib/generated-routes.d.ts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "browser": "./dist/index.js",
      "import": "./dist/index.js"
    },
    "./vite-plugin": {
      "types": "./dist/vite-plugin.d.ts",
      "import": "./dist/vite-plugin.js"
    },
    "./generated-routes-manifest": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-routes-modules": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-app-runtime": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-app-loader": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-app-middleware": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-app-plugin": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-server-routes": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-server-middleware": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-server-plugin": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./generated-config": {
      "types": "./src/lib/generated-routes.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "example:zero-config": "pnpm build && node bin/phial.mjs dev examples/zero-config",
    "test": "vitest",
    "smoke:hmr": "node scripts/hmr-smoke.mjs",
    "smoke:server-routes": "node scripts/server-routes-smoke.mjs",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@hornjs/fest": "catalog:",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "fs-route-ir": "catalog:",
    "vuepagelet": "file:../vuepagelet"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260328.1",
    "bumpp": "^11.0.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vite": "8.0.2",
    "vitest": "^4.1.2",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "peerDependencies": {
    "vite": "^8.0.0",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  }
}
